# MemoryFlow 환경변수 (deployment-notes.md / 02-trd.md)
# 로컬→서버 전환 = 이 파일만 교체. 경로를 코드에 박지 않는다.

# 서버 포트
PORT=4000

# 파일 스토리지 루트 (DB엔 이 기준 상대경로만 저장)
#   로컬:  ./storage      서버:  D:\storage
STORAGE_ROOT=./storage

# SQLite DB 경로
#   로컬:  ./data/db/memoryflow.sqlite   서버:  D:\projects\memoryflow.sqlite
DB_PATH=./data/db/memoryflow.sqlite

# 세션 쿠키 서명 시크릿 (운영에서 반드시 교체, 32자 이상)
SESSION_SECRET=change-me-please-32chars-minimum-secret

# AI 백엔드 (PRD 9장 — services/ai 어댑터). 미설정 시 로컬 스텁 사용.
#   ANTHROPIC_API_KEY=sk-ant-...
#   AI_MODEL=claude-opus-4-8
AI_PROVIDER=stub
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# ffmpeg 바이너리 경로 (PATH에 있으면 비워도 됨)
FFMPEG_PATH=
FFPROBE_PATH=
