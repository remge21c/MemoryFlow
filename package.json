{
  "name": "memoryflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"pnpm --filter @memoryflow/server dev\" \"pnpm --filter @memoryflow/client dev\"",
    "dev:server": "pnpm --filter @memoryflow/server dev",
    "dev:client": "pnpm --filter @memoryflow/client dev",
    "build": "pnpm --filter @memoryflow/shared build && pnpm --filter @memoryflow/server build && pnpm --filter @memoryflow/client build",
    "typecheck": "pnpm -r typecheck",
    "migrate": "pnpm --filter @memoryflow/server migrate",
    "seed": "pnpm --filter @memoryflow/server seed",
    "start": "pnpm --filter @memoryflow/server start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "sharp", "esbuild"]
  }
}
